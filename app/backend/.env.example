# =============================================================================
# KSP Saathi backend — environment template
# Copy to `.env` (never commit) and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Zoho Catalyst — Yaksha project (PID 47060000000020001)
# Console: https://console.catalyst.zoho.in/baas/60074155874/project/47060000000020001/Development
# -----------------------------------------------------------------------------
CATALYST_ORG_ID=60074155874
CATALYST_PROJECT_ID=47060000000020001
CATALYST_PROJECT_KEY=
CATALYST_PROJECT_DOMAIN=https://api-console.catalyst.zoho.in
CATALYST_ENVIRONMENT=Development
# Base URL for invoking deployed functions (filled in after first deploy)
CATALYST_API_BASE=https://yaksha-XXXXX.development.catalystserverless.in

# Service account credentials (downloaded from Catalyst console -> Settings -> Credentials)
CATALYST_CLIENT_ID=
CATALYST_CLIENT_SECRET=
CATALYST_REFRESH_TOKEN=

# NoSQL table names (override only if you rename them in the console)
CATALYST_AUDIT_TABLE=audit_log
CATALYST_SESSION_TABLE=session_state

# -----------------------------------------------------------------------------
# Google Gemini (Live API, 2.5 Pro, embedding-001)
# Key from https://aistudio.google.com/apikey (asia-south1 routed)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# Optional model overrides — leave blank to use defaults
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_S=0.6

# -----------------------------------------------------------------------------
# Neo4j AuraDB Free (criminal network graph)
# Created at https://console.neo4j.io — Free tier, asia-south1
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_MAX_POOL=20
NEO4J_ACQUIRE_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Google Cloud (Maps, fallback STT/TTS, optional Vertex AI Forecasting)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=ksp-saathi
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# App-level toggles
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Force the synthesizer to use Gemini 2.5 Pro instead of Qwen 2.5 14B
# (default routing: Kannada → Gemini, English → Qwen)
SYNTH_FORCE_MODEL=
