# ============================================================
# KSP Saathi — Unified environment template
# Copy to `.env` (gitignored) and fill in your own values.
# Both backend (Catalyst Functions) and frontend (Next.js)
# read from this single file. Frontend-exposed vars MUST be
# prefixed with NEXT_PUBLIC_ — everything else stays server-side.
# ============================================================


# ------------------------------------------------------------
# Zoho Catalyst — mandatory platform (90% of stack)
# ------------------------------------------------------------
# Get these from console.catalyst.zoho.in → Settings → Developer
CATALYST_PROJECT_ID=10000000000000
CATALYST_ORG_ID=60067540097
CATALYST_AUTH_TOKEN=
CATALYST_API_BASE=https://api.catalyst.zoho.in
CATALYST_ENVIRONMENT=development
# values: development | production
CATALYST_REGION=in
# India data centre — required for IT Act 2008 compliance

# Frontend-exposed Catalyst auth domain (used by AuthGate.tsx)
NEXT_PUBLIC_CATALYST_PROJECT_ID=10000000000000
NEXT_PUBLIC_CATALYST_AUTH_DOMAIN=accounts.zoho.in


# ------------------------------------------------------------
# Google Cloud — justified augmentations only
# (Gemini Live for Kannada · Gemini 2.5 Pro for premium synth
#  Maps for the geo panel · embeddings for RAG)
# All resources MUST be created in asia-south1 (Mumbai)
# ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=ksp-saathi-prod
GOOGLE_CLOUD_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Gemini API key (used by Live API + Gemini 2.5 Pro + embeddings)
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Google Maps JS API key — restrict to your domain in GCP console
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ------------------------------------------------------------
# Neo4j AuraDB Free — criminal network graph
# Sign up: https://neo4j.com/cloud/aura-free/
# Pick the GCP asia-south1 region when creating the instance.
# ------------------------------------------------------------
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j


# ------------------------------------------------------------
# Application configuration
# ------------------------------------------------------------
APP_NAME=KSP Saathi
APP_ENV=development
# values: development | staging | production
APP_REGION=asia-south1
LOG_LEVEL=info
# values: debug | info | warn | error

# Default UI language (user can override at runtime)
DEFAULT_LANGUAGE=en
# values: en | kn | hi

# Session
SESSION_TIMEOUT_MINUTES=30
SESSION_MAX_TURNS=20

# Audit log retention (days) — IT Act 2008 minimum is 180 days
AUDIT_RETENTION_DAYS=365

# Frontend public-facing app URL (used in PDF exports, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3030

# Feature flags
ENABLE_KANNADA_VOICE=true
ENABLE_PREDICTIVE_HINTS=true
ENABLE_PDF_EXPORT=true
